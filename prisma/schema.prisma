generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["academy"]
}

enum Role {
  USER
  STAFF
  ADMIN
  TRAINER

  @@schema("academy")
}

enum AccessLevel {
  FREE
  SINGLE_LESSON
  MONTHLY
  LIFETIME

  @@schema("academy")
}

model User {
  id                 String              @id @default(cuid())
  supabaseId         String?             @unique
  email              String              @unique
  passwordHash       String?
  name               String?
  avatarUrl          String?
  role               Role                @default(USER)
  mustChangePassword Boolean             @default(false)
  accessLevel        AccessLevel         @default(FREE)
  creditBalance      Int                 @default(0)
  purchasedLessonIds String              @default("[]")
  completedLessonIds String              @default("[]")
  favoriteLessonIds  String              @default("[]")
  lastOpenedLessonId String?
  assessmentResult   String?
  stripeCustomerId   String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  creditTransactions CreditTransaction[]
  trainerContracts   TrainerContract[]
  adminNotifications AdminNotification[]
  trainerProfile     CertifiedTrainer?
  conversationParticipants ConversationParticipant[]
  sentMessages       Message[]             @relation("SentMessages")

  @@schema("academy")
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  reason      String
  lessonId    String?
  createdById String?
  createdAt   DateTime @default(now())

  @@schema("academy")
}

model ErrorLog {
  id        String   @id @default(cuid())
  severity  String
  area      String
  message   String
  userEmail String?
  url       String?
  device    String?
  status    String   @default("open")
  createdAt DateTime @default(now())

  @@schema("academy")
}

model AiAssistLog {
  id              String   @id @default(cuid())
  userId          String?
  sessionId       String?
  lessonId        String?
  pageUrl         String?
  actionType      String
  promptTokens    Int?
  responseTokens  Int?
  responseTimeMs  Int?
  status          String
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@schema("academy")
}

model LessonAiSummary {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  lessonTitle     String
  summaryJson     String
  model           String
  contentHash     String
  lastGeneratedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@schema("academy")
}

model AiHealthCheck {
  id             String   @id @default(cuid())
  service        String
  status         String
  responseTimeMs Int?
  errorMessage   String?
  metadata       String?
  createdAt      DateTime @default(now())

  @@schema("academy")
}

model CertifiedTrainer {
  id             String            @id @default(cuid())
  slug           String            @unique
  name           String
  email          String
  title          String
  bio            String
  about          String?
  philosophy     String?
  quote          String?
  quoteAuthor    String?
  specialties    String            @default("[]")
  classes        String            @default("[]")
  qualifications String            @default("[]")
  photoUrl       String?
  userId         String?           @unique
  user           User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  contracts      TrainerContract[]

  @@schema("academy")
}

model TrainerContract {
  id               String           @id @default(cuid())
  ownerId          String
  owner            User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  trainerId        String
  trainer          CertifiedTrainer @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  status           String           @default("pending_admin")
  dogName          String?
  dogBreed         String?
  dogAge           String?
  dogNotes         String?
  ownerMessage     String?
  assessmentReport String?
  reportSummary    String?
  trainerNotified  Boolean          @default(false)
  adminNotified    Boolean          @default(false)
  approvedAt       DateTime?
  approvedById     String?
  conversation     Conversation?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([ownerId])
  @@index([trainerId])
  @@index([status])
  @@schema("academy")
}

model Conversation {
  id           String                    @id @default(cuid())
  contractId   String?                   @unique
  contract     TrainerContract?          @relation(fields: [contractId], references: [id], onDelete: SetNull)
  subject      String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]

  @@schema("academy")
}

model ConversationParticipant {
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
  @@schema("academy")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@schema("academy")
}

model AdminNotification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  metadata  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
  @@schema("academy")
}

model UserActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  actorId    String?
  actorEmail String?
  category   String
  action     String
  summary    String
  metadata   String?
  targetType String?
  targetId   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([category])
  @@index([action])
  @@schema("academy")
}
