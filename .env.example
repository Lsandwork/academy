DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth (anon key is safe for the browser; never expose service role client-side)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Legacy — no longer used for login after Supabase migration
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Stripe — create products/prices at https://dashboard.stripe.com
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_SINGLE_LESSON="price_..."
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_LIFETIME="price_..."

# Fitdog AI Assist (server-side only — never use NEXT_PUBLIC_ prefix)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
AI_ASSIST_ENABLED=true
AI_SUMMARY_CACHE_ENABLED=true
AI_ASSIST_LOGGING_ENABLED=true
AI_ASSIST_ADMIN_DIAGNOSTICS_ENABLED=true

# Optional — base URL for hosted lesson videos (e.g. https://your-project.supabase.co/storage/v1/object/public/lessons)
# Each lesson resolves to {FITDOG_VIDEO_CDN}/{lesson-id}.mp4
# Without this, lessons show track preview embeds until you upload MP4s.
FITDOG_VIDEO_CDN=""
